{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Agent",
  "version": "1.1.0",
  "identifier": "com.hermes.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Agent",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.minimax.chat https://api.minimaxi.com https://*.minimax.io http://175.27.242.158:5000 http://43.128.59.90:18789 http://127.0.0.1:9122 http://127.0.0.1:9119; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; frame-src 'self' http://127.0.0.1:9122 http://127.0.0.1:9119"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1NzM4RUNGRjdFNEM4OEYKUldTUHlPVDN6NDV6ZGMxL3kzWHVrRW04TXhKQnZ2TW82US9QODQyaWUwV0t4Q3VjM1ljZGc5WkgK",
      "endpoints": [
        "https://github.com/5bqp2tjdnc-prog/hermes-windows/releases/latest/download/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["hermes-agent.zip", "resources/hermes-webui.zip", "resources/hermes_chat_server.py"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
